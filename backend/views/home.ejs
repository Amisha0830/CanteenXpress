    <!-- ==================== JAVASCRIPT ==================== -->
    <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
        let cartCount = 3;

        // Mobile Menu
        function toggleMobileMenu() {
            document.getElementById('mobileMenu').classList.add('active');
            document.getElementById('overlay').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeMobileMenu() {
            document.getElementById('mobileMenu').classList.remove('active');
            document.getElementById('overlay').classList.remove('active');
            document.body.style.overflow = '';
        }

        // Floating cart button — appears on scroll (replaces scroll-to-top)
        window.addEventListener('scroll', function () {
            const floatingCart = document.getElementById('floatingCart');
            if (window.pageYOffset > 280) {
                floatingCart.classList.add('visible');
            } else {
                floatingCart.classList.remove('visible');
            }
        });

        // Category filter
        document.querySelectorAll('.category-card').forEach(card => {
            card.addEventListener('click', function () {
                document.querySelectorAll('.category-card').forEach(c => c.classList.remove('active'));
                this.classList.add('active');
            });
        });

        // Cart count sync helper
        function updateCartCount(count) {
            cartCount = count;
            const els = ['navCartCount', 'floatingCartCount', 'mobileCartCount'];
            els.forEach(id => {
                const el = document.getElementById(id);
                if (el) el.textContent = count;
            });
        }

        // Navbar shadow on scroll (fixed)
        const navbar = document.querySelector('.navbar');
        window.addEventListener('scroll', function () {
            if (window.pageYOffset > 10) {
                navbar.style.background = 'rgba(255,255,255,0.98)';
                navbar.style.boxShadow = '0 4px 20px rgba(0,0,0,0.08)';
            } else {
                navbar.style.background = 'rgba(255,255,255,0.95)';
                navbar.style.boxShadow = 'none';
            }
        });

        // Search on Enter
        const searchInput = document.querySelector('.search-bar input');
        if (searchInput) {
            searchInput.addEventListener('keyup', function (e) {                if (e.key === 'Enter' && this.value.trim()) {
                    window.location.href = '/menu?q=' + encodeURIComponent(this.value.trim());
                }
            });
        }

        // ==================== AUTO-ROTATING SPECIALS ====================
        const allOffers = [
            { icon: 'fa-bowl-food',       tag: '50% OFF',         name: 'Combo Meal',        desc: 'Burger + Fries + Cold Drink',     price: '₹99' },
            { icon: 'fa-pizza-slice',     tag: 'Buy 1 Get 1',     name: 'Pizza Tuesday',     desc: 'Free pizza on your 2nd purchase', price: '₹199' },
            { icon: 'fa-mug-hot',         tag: 'Morning Special', name: 'Breakfast Combo',   desc: 'Poha + Chai + Toast',             price: '₹60' },
            { icon: 'fa-drumstick-bite',  tag: '30% OFF',         name: 'Chicken Wings',     desc: 'Crispy wings with buffalo sauce', price: '₹99' },
            { icon: 'fa-utensils',        tag: 'Lunch Deal',      name: 'Chicken Biryani',   desc: 'Aromatic rice with raita',        price: '₹110' },
            { icon: 'fa-burger',          tag: 'Flash Sale',      name: 'Veggie Burger',     desc: 'Fresh lettuce, tomato & sauce',   price: '₹65' },
            { icon: 'fa-ice-cream',       tag: 'Evening Special', name: 'Dessert Combo',     desc: 'Ice cream + Cold coffee',         price: '₹75' },
            { icon: 'fa-leaf',            tag: 'Healthy Pick',    name: 'Green Bowl',        desc: 'Salad + Juice + Sprouts',         price: '₹80' },
            { icon: 'fa-bread-slice',     tag: 'Snack Time',      name: 'Sandwich Meal',     desc: 'Veg sandwich + Chips + Tea',      price: '₹55' },
        ];

        const VISIBLE = 3; // how many cards shown at once
        let currentPage = 0;
        let autoTimer = null;
        let shuffled = [];

        function shuffle(arr) {
            const a = [...arr];
            for (let i = a.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [a[i], a[j]] = [a[j], a[i]];
            }
            return a;
        }

        function totalPages() {
            return Math.ceil(shuffled.length / VISIBLE);
        }

        function renderDots() {
            const dotsEl = document.getElementById('specialsDots');
            if (!dotsEl) return;
            dotsEl.innerHTML = '';
            for (let i = 0; i < totalPages(); i++) {
                const btn = document.createElement('button');
                btn.className = 'specials-dot' + (i === currentPage ? ' active' : '');
                btn.onclick = () => goToPage(i);
                dotsEl.appendChild(btn);
            }
        }

        function renderCards(animate) {
            const grid = document.getElementById('specialsGrid');
            if (!grid) return;

            const start = currentPage * VISIBLE;
            const slice = shuffled.slice(start, start + VISIBLE);

            if (animate) {
                grid.classList.add('fade-out');
                setTimeout(() => {
                    grid.innerHTML = buildCards(slice);
                    grid.classList.remove('fade-out');
                    grid.classList.add('fade-in');
                    setTimeout(() => grid.classList.remove('fade-in'), 300);
                }, 250);
            } else {
                grid.innerHTML = buildCards(slice);
            }
            renderDots();
        }

        function buildCards(items) {
            return items.map(o => `
                <div class="special-card">
                    <div class="special-image">
                        <i class="fas ${o.icon}" style="font-size:36px;color:var(--primary);"></i>
                    </div>
                    <div class="special-content">
                        <span class="special-tag">${o.tag}</span>
                        <h3 class="special-name">${o.name}</h3>
                        <p class="special-description">${o.desc}</p>
                        <div class="special-footer">
                            <span class="special-price">${o.price}</span>
                            <button class="special-btn">Order Now</button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function goToPage(page) {
            currentPage = page;
            renderCards(true);
            resetTimer();
        }

        function changeSpecials(dir) {
            currentPage = (currentPage + dir + totalPages()) % totalPages();
            renderCards(true);
            resetTimer();
        }

        function resetTimer() {
            clearInterval(autoTimer);
            autoTimer = setInterval(() => {
                currentPage = (currentPage + 1) % totalPages();
                renderCards(true);
            }, 4000);
        }

        // Init: shuffle all offers and pick random starting page
        function initSpecials() {
            shuffled = shuffle(allOffers);
            currentPage = Math.floor(Math.random() * totalPages());
            renderCards(false);
            resetTimer();
        }

        document.addEventListener('DOMContentLoaded', initSpecials);

    </script>
</body>
